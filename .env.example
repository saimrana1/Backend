MONGODB_URI="mongodb://127.0.0.1:27017/cms_admin"
PORT=5000
NODE_ENV=development

# When set, all /api/v1/admin/* routes require header: x-admin-api-key: <value>
ADMIN_API_KEY=

# JWT for POST /api/v1/auth/login and /register (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Set to false to disable public sign-up (login still works)
AUTH_SIGNUP_ENABLED=true
